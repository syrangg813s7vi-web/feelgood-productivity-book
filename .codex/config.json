      "chapter_template": [
        "X.1 核心概念 - 理论基础和科学依据",
        "X.2 系统框架 - 方法、步骤、工具",
        "X.3 实战案例 - 至少3个详细案例",
        "X.4 常见问题 - FAQ和故障排除",
        "X.5 行动清单 - 7天启动和30天进阶",
        "本章总结 - 核心要点回顾",
        "练习和思考 - 实战作业"
      ],
      "words_per_section": {
        "concept": 2000,
        "framework": 3000,
        "cases": 4000,
        "faq": 2000,
        "action": 2000,
        "summary": 1000
      },
      "total_words_per_chapter": "10000-15000"
    },

    "quality_standards": {
      "accuracy": "基于原始视频内容，不编造",
      "completeness": "覆盖主题所有关键要点",
      "readability": "使用简单直白的语言",
      "practicality": "提供可操作的方法和工具",
      "coherence": "与前后章节自然衔接"
    }
  },

