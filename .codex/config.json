      "4. 分析已完成章节的写作风格",
      "5. 续写新章节内容",
      "6. 保存到book/目录",
      "7. 提示用户审核并提交到GitHub"
    ],

    "auto_commit": true,
    "create_pr": true,
    "branch_naming": "chapter-N"
  },

